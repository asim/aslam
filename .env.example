# Anthropic API key (required for AI responses)
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (optional, defaults to claude-3-haiku-20240307)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database encryption key (optional if ~/.nasir/.key exists)
# NASIR_KEY=your-encryption-key

# Database path (optional, defaults to ~/.nasir/nasir.db)
# NASIR_DB=/path/to/nasir.db

# Server port (optional, defaults to 8000)
# PORT=8000
